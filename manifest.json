{
  "manifest_version": 3,
  "name": "HandyVoice Bridge",
  "version": "1.3.5",
  "description": "Secure haptic bridge for LLM interfaces.",
  "permissions": [
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://api.handyfeeling.com/*",
    "https://*.x.ai/*",
    "https://*.google.com/*",
    "https://*.claude.ai/*",
    "https://*.perplexity.ai/*",
    "https://*.openai.com/*",
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.x.ai/*",
        "https://*.google.com/*",
        "https://*.claude.ai/*",
        "https://*.perplexity.ai/*",
        "https://*.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}